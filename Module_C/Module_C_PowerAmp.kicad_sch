	(text "U2 TPA3251 — Class D Power Amplifier (70W/8ohm)\nNot in default KiCad libs — create custom symbol.\nConnect: IN+<-TPA_INP  IN-<-TPA_INN\nPVCC<-PVCC_32V  GVDD->C7  AVDD->C10\nOUTA->OUT_A  OUTB->OUT_B\nBSTA->BST_A(C8)  BSTB->BST_B(C9)\nSD<-R8(GVDD pullup)  FAULT->R9+LED1\nGAIN0=GND  GAIN1=GND (26dB)\nPGND=GND  GND=GND"
		(exclude_from_sim no)
		(at 184.17 116.79 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "87e8ace5-8fdf-4fa2-ae78-8ad52634606f")
	)
	(text "U1 NE5532 — SE-to-Differential Converter\nHalf 1 (pins 1,2,3): Unity-gain buffer -> DIFF_P\nHalf 2 (pins 5,6,7): Unity-gain inverter -> DIFF_N\nV+ pin 8 -> +12V   V- pin 4 -> GND\nAdd NE5532 from Amplifier_Audio library."
		(exclude_from_sim no)
		(at 118.872 51.562 0)
		(effects
			(font
				(size 1.27 1.27)
			)
